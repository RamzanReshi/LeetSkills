# Supabase Auth
# Leave these blank for anonymous local demo mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI evaluation provider
# Valid values: claude, gemini, openai
AI_PROVIDER=claude

# Claude
ANTHROPIC_API_KEY=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI
# The provider is currently a stub and is not production-ready.
OPENAI_API_KEY=
